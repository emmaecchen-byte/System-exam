{
  "name": "exam-system-backend",
  "version": "0.1.0",
  "description": "Internal Examination System API",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "prebuild": "prisma generate",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "prisma generate && prisma db push --skip-generate && nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node prisma/seed.ts",
    "db:setup": "prisma migrate dev && ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/bull": "^11.0.4",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.19.3",
    "@vercel/node": "^5.8.15",
    "bcrypt": "^5.1.1",
    "bull": "^4.16.5",
    "bullmq": "^5.78.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "exceljs": "^4.4.0",
    "ioredis": "^5.4.2",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "redis": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "serverless-http": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.0.9",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.6",
    "eslint": "^9.39.4",
    "prisma": "^6.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
