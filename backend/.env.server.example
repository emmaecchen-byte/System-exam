# Copy to backend/.env on the Linux server (see scripts/setup-linux-server.sh)

DATABASE_URL="file:./dev.db"
REDIS_ENABLED=false
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_EXPIRES_IN="8h"
JWT_REMEMBER_EXPIRES_IN="7d"
SESSION_INACTIVITY_MINUTES=30
PORT=3000
HOST=0.0.0.0
UPLOAD_DIR="./uploads"
CORS_ORIGIN="http://172.16.20.7:8895,http://localhost:8895"
FRONTEND_URL="http://172.16.20.7:8895"
QR_TOKEN_SECRET="change-me-qr-token-secret"
INTERNAL_API_KEY="change-me-internal-api-key"

# DeepSeek LLM — add your API key to enable automatic short-answer grading
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-pro"
DEEPSEEK_TIMEOUT_MS=30000
