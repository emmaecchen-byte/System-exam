# Local dev (no Docker): SQLite
# Path is relative to backend/prisma/schema.prisma → backend/prisma/dev.db
DATABASE_URL="file:./dev.db"

# Production / Docker: PostgreSQL
# DATABASE_URL="postgresql://exam:exam_secret@localhost:5432/exam_system?schema=public"

# Redis (exam timers, QR token cache, auto-save queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Set to false to skip Redis and use database-only fallback (local dev without Docker)
# REDIS_ENABLED=false
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_EXPIRES_IN="8h"
JWT_REMEMBER_EXPIRES_IN="7d"
SESSION_INACTIVITY_MINUTES=30
PORT=3000
UPLOAD_DIR="./uploads"
CORS_ORIGIN="http://localhost:5173,http://127.0.0.1:5173"
FRONTEND_URL="http://localhost:5173"
QR_TOKEN_SECRET="change-me-qr-token-secret"
INTERNAL_API_KEY="change-me-internal-api-key"
