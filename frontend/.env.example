# Session inactivity timeout in minutes (default: 30)
VITE_SESSION_TIMEOUT_MINUTES=30

# API URL — leave empty for local dev (Vite proxies /api → http://localhost:3000)
# For Vercel/static hosting, set to your running API, e.g.:
# VITE_API_BASE_URL=https://your-tunnel-or-api.example.com/api
VITE_API_BASE_URL=
# API port on your Mac for phone/LAN access (default 3000)
VITE_API_PORT=3000
